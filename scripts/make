PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
old_pwd="$(pwd)"
cd $PROJECT_ROOT

if [ ! -d "_live_code" ]; then
    mkdir _live_code
    cd _live_code
    touch solution.py
    touch tests_output.txt
    cd ..
fi

if [ ! -f "./.env" ]; then
  sh scripts/init_env
fi

npm install

cd $old_pwd
